# ===========================================
# Quadros Prompt Generator - Environment Variables
# ===========================================

# App
VITE_APP_ID=quadros-prompt-generator
JWT_SECRET=your-jwt-secret-here
DATABASE_URL=mysql://user:password@localhost:3306/quadros

# Google Cloud - API Key (para Imagen e Veo)
GOOGLE_API_KEY=your-google-api-key

# Google Cloud - OAuth 2.0 (para autenticacao e Drive)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://quadros-gerador-entregas-production.up.railway.app/api/oauth/google/callback

# Google Cloud - Project
GOOGLE_PROJECT_ID=your-project-id

# Google Drive - Pasta para salvar imagens geradas (fluxo manual existente)
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# Google Drive - Pasta raiz do banco de imagens "Catálogo Imagens"
# (origem do passo 1 do pipeline Tray: contém subpastas por categoria)
DRIVE_BANK_FOLDER_ID=1q9lmdE2amuPQtPT7Cmp0pokCIvnmqpgN

# Google Drive - Pasta destino onde o pipeline cria as pastas [SKU] de
# cada produto e publica as imagens com permissão pública (URLs Tray).
DRIVE_DESTINATION_FOLDER_ID=17TZWPx9UoxGYjbyOUT7mN67KqZA1wQfA
