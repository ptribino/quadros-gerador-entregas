# ===========================================
# Quadros Prompt Generator - Environment Variables
# ===========================================

# App
VITE_APP_ID=quadros-prompt-generator
JWT_SECRET=your-jwt-secret-here
DATABASE_URL=mysql://user:password@localhost:3306/quadros

# Google Cloud - API Key (para Imagen e Veo)
GOOGLE_API_KEY=your-google-api-key

# Google Cloud - OAuth 2.0 (para autenticacao e Drive)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://quadros-gerador-entregas-production.up.railway.app/api/oauth/google/callback

# Google Cloud - Project
GOOGLE_PROJECT_ID=your-project-id

# Google Drive - Pasta para salvar imagens geradas
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id
